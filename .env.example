# Environment variables for AI Humanizer
# Copy this to .env.local for development

# NextAuth
NEXTAUTH_URL=https://aihumanizer.life
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_PLAN_ID_MONTHLY=your-monthly-plan-id
PAYPAL_PLAN_ID_YEARLY=your-yearly-plan-id

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Cron secret
CRON_SECRET=aihumanizer-cron-2026
